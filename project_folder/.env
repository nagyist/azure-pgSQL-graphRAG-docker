DB_TYPE="Azure SQL"  # "Azure SQL" or "Azure postgres"
MY_DB_HOST=
MY_DB_PORT=
MY_DB_USER=
MY_DB_PASSWORD=
MY_DB_NAME=
MY_DB_SSLMODE=disable
PROMPTS=/app/graphrag-folder/prompts
CONFIG_PATH=/app/graphrag-folder/settings.yaml
AGE_HOST=postgres
AGE_PORT=5432
AGE_USER=postgres
AGE_PASSWORD=xxxx
AGE_DB=postgres
USE_LOCAL_AGE=true
AOAI_API_BASE="https://xxxx.openai.azure.com"
AOAI_API_KEY=xxxx
AOAI_LLM_MODEL=gpt-4o
AOAI_LLM_API_VERSION="2025-01-01-preview"
AOAI_LLM_DEPLOYMENT=gpt-4o
AOAI_EMBEDDING_MODEL=text-embedding-3-small
AOAI_EMBEDDING_API_VERSION="2023-05-15"
AOAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

